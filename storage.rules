rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Spark-compatible mode. Strict role checks require the callable
    // Functions/custom-token flow, which cannot deploy until the project is on Blaze.
    match /logos/{fileName} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /vendor-orders/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 15 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
