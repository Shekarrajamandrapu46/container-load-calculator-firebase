rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Spark-compatible mode:
    // The app uses admin-issued PINs stored in Firestore and validates them in
    // the browser when Cloud Functions are unavailable. Strict role rules need
    // Blaze + callable Functions/custom tokens, which are implemented in code
    // but cannot be deployed on the current Spark project.
    match /accessPins/{pinId} {
      allow read, write: if true;
    }

    match /meherRegions/{regionId} {
      allow read, write: if true;
    }

    match /vendorDirectory/{vendorCode} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /vendorOrderUploads/{uploadId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
